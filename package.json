{
  "name": "openone",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered productivity workspace that connects Gmail, GitHub, Slack, Calendar, and developer tools into a unified platform.",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "git clean -xfd node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faizan-devs/openone.git"
  },
  "keywords": [
    "ai",
    "productivity",
    "gmail",
    "calendar",
    "slack",
    "github"
  ],
  "author": "Faizan Alam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/faizan-devs/openone/issues"
  },
  "homepage": "https://github.com/faizan-devs/openone#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  }
}